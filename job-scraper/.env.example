# Get tokens from https://console.apify.com/account/integrations
# Multiple accounts? Comma-separate them — the app rotates to the next when one's
# monthly credit runs out, so you never swap tokens manually:
APIFY_TOKENS=apify_api_token1,apify_api_token2,apify_api_token3
# (A single APIFY_TOKEN=... or numbered APIFY_TOKEN_1, APIFY_TOKEN_2 also work.)

# For the resume generator — get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the model (default gpt-5-mini)
OPENAI_MODEL=gpt-5-mini
